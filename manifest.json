{
  "manifest_version": 3,
  "name": "Beck Auto-Post",
  "version": "1.1.0",
  "description": "Automate Facebook Marketplace vehicle listings by matching photos to VIN, extracting CSV data, and generating descriptions",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "alarms",
    "permissions",
    "downloads"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://*.facebook.com/*",
    "https://beck-sftp-proxy-production.up.railway.app/*",
    "https://assets.cai-media-management.com/*",
    "https://*.cai-media-management.com/*",
    "https://dm-next-images.s3.us-east-2.amazonaws.com/*",
    "https://dm-next-images.s3.amazonaws.com/*",
    "https://vehicle-photos-published.vauto.com/*",
    "https://*.beckchryslerdodgejeep.com/*",
    "https://*.becknissan.com/*",
    "https://*.beckfordlinc.com/*",
    "https://*.beckchevrolet.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/beck-logo.png",
      "48": "icons/beck-logo.png",
      "128": "icons/beck-logo.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/create/*",
        "https://www.facebook.com/marketplace/*/create/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/beck-logo.png",
    "48": "icons/beck-logo.png",
    "128": "icons/beck-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["utils/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}

